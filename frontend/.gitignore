# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ─── Dependencies ────────────────────────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ─── Next.js ─────────────────────────────────────────────────────────────────
/.next/
/out/
/build
next-env.d.ts
*.tsbuildinfo

# ─── Testing & Coverage ──────────────────────────────────────────────────────
/coverage
/test-results/
/playwright-report/
/playwright/.cache/

# ─── Environment & Secrets ───────────────────────────────────────────────────
.env
.env.*
!.env.example
!.env.test
*.pem
*.key
*.cert
*.p12

# ─── AI / Claude Code / Agentic Workflow ─────────────────────────────────────
.claude/
.agents/
CLAUDE.md
AGENTS.md
SYSTEM_FLOW.md
skills-lock.json
.cursorrules
.cursorignore
.cursor/
.aider*
.codeium/
.copilot/
*.prompt
memory/

# ─── IDE & Editors ───────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*~

# ─── OS Generated Files ──────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Desktop.ini
Thumbs.db

# ─── Logs ────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-debug.log*

# ─── Cache & Temp ────────────────────────────────────────────────────────────
.cache/
.turbo/
.parcel-cache/
*.tmp
*.temp
*.bak

