# =============================================================================
# SISTEM INVENTORY — Frontend Environment Variables
# =============================================================================
# Salin file ini ke .env.local lalu isi setiap value yang kosong.
#   cp .env.example .env.local
#
# Nilai <project-ref> didapat dari Supabase Dashboard → Project Settings → General
# Nilai key didapat dari Supabase Dashboard → Project Settings → API
# =============================================================================


# ─── DATABASE ─────────────────────────────────────────────────────────────────

# URL koneksi database melalui PgBouncer (connection pooling).
# Digunakan oleh Prisma saat runtime (query di API routes).
# Format: postgresql://postgres.<project-ref>:<db-password>@<pooler-host>:6543/postgres?pgbouncer=true
DATABASE_URL=""

# URL koneksi langsung ke database (tanpa pooler).
# Digunakan oleh Prisma untuk migrasi/schema push (prisma db push, prisma migrate).
# Format: postgresql://postgres.<project-ref>:<db-password>@db.<project-ref>.supabase.co:5432/postgres
DIRECT_URL=""


# ─── SUPABASE ─────────────────────────────────────────────────────────────────

# URL project Supabase. Nilai ini aman di-expose ke browser (prefix NEXT_PUBLIC_).
# Didapat dari: Supabase Dashboard → Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=""

# Anon/public key Supabase. Aman di-expose ke browser, hanya bisa akses data
# sesuai Row Level Security (RLS) policy.
# Didapat dari: Supabase Dashboard → Project Settings → API → Project API Keys → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# Service role key Supabase. RAHASIA — hanya digunakan di server-side (API routes).
# Membypass RLS, jangan pernah kirim ke browser atau commit ke repository.
# Didapat dari: Supabase Dashboard → Project Settings → API → Project API Keys → service_role
SUPABASE_SERVICE_ROLE_KEY=""


# ─── APP ──────────────────────────────────────────────────────────────────────

# URL publik aplikasi. Digunakan untuk membangun absolute URL (email link, redirect, dll).
# Development: http://localhost:3000
# Production: https://your-domain.com
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# URL callback setelah proses login Supabase Auth selesai.
# Harus ditambahkan ke Supabase Dashboard → Authentication → URL Configuration → Redirect URLs.
AUTH_REDIRECT_URL="http://localhost:3000/auth/callback"


# ─── NODE ─────────────────────────────────────────────────────────────────────

# Environment mode aplikasi. Nilai: development | production | test
NODE_ENV="development"
