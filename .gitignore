# ─── Root-level gitignore (monorepo) ─────────────────────────────────────────
# Aturan ini berlaku untuk SELURUH folder dalam repo (frontend/ dan backend/).
# Aturan spesifik per-folder juga ada di frontend/.gitignore & backend/.gitignore

# =============================================================================
# DEPENDENCIES — Jangan pernah commit node_modules
# =============================================================================
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# =============================================================================
# ENVIRONMENT & SECRETS — KRITIS: jangan sampai bocor ke GitHub
# =============================================================================
.env
.env.local
.env.development
.env.production
.env.staging
.env.test
.env.*.local
.env.*
# Kecualikan file contoh (template), file ini aman untuk di-commit
!.env.example
!.env.test.example

# Sertifikat dan kunci kriptografi
*.pem
*.key
*.cert
*.p12
*.pfx
*.crt
*.ca-bundle

# =============================================================================
# NEXT.JS — Build output & cache
# =============================================================================
.next/
out/
build/
next-env.d.ts
*.tsbuildinfo

# =============================================================================
# PRISMA — File yang di-generate otomatis
# =============================================================================
generated/

# =============================================================================
# SUPABASE — File temporary CLI & config lokal
# =============================================================================
supabase/.temp/
.supabase/

# =============================================================================
# MCP / AI TOOLS CONFIG — Berisi referensi project & API keys
# =============================================================================
.mcp.json

# =============================================================================
# AI / CLAUDE CODE / AGENTIC WORKFLOW
# File-file ini adalah konfigurasi lokal AI assistant, bukan bagian dari kode
# =============================================================================
.claude/
.agents/
memory/
CLAUDE.md
AGENTS.md
SYSTEM_FLOW.md
skills-lock.json

# Tools AI lain
.cursorrules
.cursorignore
.cursor/
.aider*
.codeium/
.copilot/
*.prompt

# =============================================================================
# TESTING & COVERAGE
# =============================================================================
coverage/
.nyc_output/
test-results/
playwright-report/
playwright/.cache/

# =============================================================================
# IDE & EDITOR
# =============================================================================
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*~
*.suo
*.user
*.userosscache
*.sln.docstates

# =============================================================================
# OS GENERATED FILES
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
Desktop.ini
ehthumbs.db

# =============================================================================
# LOGS
# =============================================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-debug.log*
lerna-debug.log*

# =============================================================================
# CACHE & TEMP FILES
# =============================================================================
.cache/
.turbo/
.parcel-cache/
*.tmp
*.temp
*.bak
*.swp

# =============================================================================
# LOCAL DATABASE FILES
# =============================================================================
*.sqlite
*.sqlite3
*.db

# =============================================================================
# DEPLOYMENT CONFIG LOKAL
# =============================================================================
.vercel
.netlify

# =============================================================================
# PACKAGE MANAGER — Lock files sudah di-cover tapi ini untuk yang lain
# =============================================================================
.npm/
